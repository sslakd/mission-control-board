<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🚀 Mission Control — Jason</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<script src="https://unpkg.com/vue@3/dist/vue.global.prod.js"></script>
<style>
  :root{--bg:#0f172a;--card:#1e293b;--card2:#334155;--sidebar:#0b1121;--accent:#38bdf8;--green:#22c55e;--yellow:#eab308;--red:#ef4444;--muted:#64748b;--border:#1e293b;--hover:#1a2744;--text:#e2e8f0;--text2:#94a3b8}
  *{margin:0;padding:0;box-sizing:border-box}
  body{background:var(--bg);color:var(--text);font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;padding:20px;min-height:100vh}
  .container{max-width:1200px;margin:0 auto}
  h1{font-size:24px;margin-bottom:24px;display:flex;align-items:center;gap:10px}
  .count{font-size:12px;font-weight:400;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-left:4px}
  
  /* Task Table */
  .task-table{width:100%;overflow-x:auto;background:var(--card);border-radius:12px;border:1px solid var(--border)}
  .task-table-header{display:flex;padding:10px 12px;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:1px;color:var(--muted);background:var(--card2);border-radius:8px 8px 0 0}
  .task-table-header>div{padding:0 8px}
  .task-table-header .col-task{flex:3}
  .task-table-header .col-priority{flex:0 0 72px;text-align:center}
  .task-table-header .col-deadline{flex:0 0 100px;text-align:center}
  .task-table-header .col-progress{flex:0 0 160px;text-align:center}
  .task-table-header .col-status{flex:0 0 100px;text-align:center}
  .task-table-header .col-actions{flex:0 0 50px;text-align:center}
  
  .task-row{display:flex;align-items:center;padding:12px;border-bottom:1px solid var(--border);cursor:pointer;transition:background .15s}
  .task-row:last-child{border-bottom:none;border-radius:0 0 8px 8px}
  .task-row:hover{background:var(--hover)}
  .task-row>div{padding:0 8px}
  .col-task{flex:3;min-width:0}
  .col-priority{flex:0 0 72px;min-width:72px;text-align:center}
  .col-deadline{flex:0 0 100px;min-width:100px;text-align:center}
  .col-progress{flex:0 0 160px;min-width:160px;text-align:center}
  .col-status{flex:0 0 100px;min-width:100px;text-align:center}
  .col-actions{flex:0 0 50px;min-width:50px;text-align:center}
  
  .task-name{font-weight:600;font-size:14px;display:flex;align-items:center;gap:8px}
  .task-desc{font-size:12px;color:var(--muted);margin-top:2px;line-height:1.3}
  .task-done .task-name{text-decoration:line-through;opacity:.6}
  
  .tag{font-size:11px;padding:2px 8px;border-radius:6px;white-space:nowrap}
  .tag.p1{background:#7f1d1d;color:#fca5a5}
  .tag.p2{background:#713f12;color:var(--yellow)}
  .tag.p3{background:#1e3a5f;color:#93c5fd}
  
  .deadline{font-size:11px;padding:2px 8px;border-radius:4px;white-space:nowrap}
  .deadline.warn{background:#713f12;color:var(--yellow)}
  .deadline.ok{background:#166534;color:var(--green)}
  
  .status-badge{font-size:11px;padding:3px 10px;border-radius:12px;display:inline-flex;align-items:center;gap:4px;white-space:nowrap}
  .status-badge.in-progress{background:#1e3a5f;color:var(--accent)}
  .status-badge.done{background:#166534;color:var(--green)}
  .status-badge.pending{background:#713f12;color:var(--yellow)}
  .status-badge.paused{background:#374151;color:var(--muted)}
  .status-badge.auto{background:#166534;color:var(--green)}
  
  .progress-bar{width:60px;height:6px;background:var(--card2);border-radius:3px;display:inline-block;overflow:hidden;vertical-align:middle}
  .progress-fill{height:100%;border-radius:3px;background:linear-gradient(90deg,var(--accent),#60a5fa);transition:width .5s}
  .progress-text{font-size:11px;color:var(--muted);margin-left:4px;white-space:nowrap}
  
  .checkbox{width:18px;height:18px;border:2px solid var(--muted);border-radius:4px;display:inline-flex;align-items:center;justify-content:center;cursor:pointer;transition:.2s;flex-shrink:0}
  .checkbox.checked{background:var(--green);border-color:var(--green)}
  .checkbox.checked i{color:#fff;font-size:11px}
  .checkbox:hover{border-color:var(--accent)}
  
  .btn{background:var(--card2);border:none;color:var(--text2);cursor:pointer;padding:4px 8px;border-radius:4px;font-size:11px;transition:.2s}
  .btn:hover{background:var(--hover);color:var(--text)}
  
  /* Modal */
  .modal-overlay{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.6);z-index:1000;display:flex;align-items:center;justify-content:center}
  .modal{background:var(--card);border-radius:16px;padding:24px;max-width:700px;width:90%;max-height:85vh;overflow-y:auto}
  .modal h2{font-size:20px;margin-bottom:16px;display:flex;align-items:center;gap:8px}
  .modal-close{float:right;background:none;border:none;color:var(--muted);font-size:20px;cursor:pointer}
  .modal-close:hover{color:var(--text)}
  .modal-section{margin-bottom:20px}
  .modal-section h3{font-size:14px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px}
  .modal-meta{display:flex;gap:16px;flex-wrap:wrap}
  .modal-meta-item{font-size:13px;display:flex;align-items:center;gap:4px}
  
  .subtask-list{margin-top:8px}
  .subtask-item{display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:8px;cursor:pointer;transition:.15s}
  .subtask-item:hover{background:var(--hover)}
  .subtask-item.done .subtask-label{text-decoration:line-through;opacity:.6}
  .subtask-label{font-size:13px;flex:1}
  .subtask-value{font-size:12px;color:var(--muted)}

  .file-viewer{background:var(--bg);border-radius:8px;padding:16px;margin-top:8px;max-height:300px;overflow-y:auto;font-size:12px;line-height:1.5;white-space:pre-wrap;color:var(--text2);font-family:monospace}

  .edit-inline{background:transparent;border:1px solid var(--border);color:var(--text);padding:4px 8px;border-radius:4px;font-size:13px;width:120px}
  .edit-inline:focus{outline:none;border-color:var(--accent)}
  select.edit-inline{width:auto;cursor:pointer}
  
  /* Mobile */
  @media(max-width:768px){
    .task-table-header,.col-desc-mobile{display:none!important}
    .task-row{flex-wrap:wrap;padding:14px;margin-bottom:10px;border:1px solid var(--border);border-radius:12px}
    .col-task{flex:1 1 100%;margin-bottom:8px}
    .col-priority{flex:0 0 auto;min-width:auto;order:1}
    .col-deadline{flex:0 0 auto;min-width:auto;order:2}
    .col-progress{flex:0 0 auto;min-width:auto;order:3}
    .col-status{flex:0 0 auto;min-width:auto;order:4}
    .col-actions{display:none!important}
    .task-desc{display:none!important}
    .progress-bar{width:40px}
  }

  .fade-enter-active,.fade-leave-active{transition:opacity .2s}
  .fade-enter-from,.fade-leave-to{opacity:0}
</style>
</head>
<body>
<div id="app" class="container">
  <h1>🚀 Mission Control <span class="count">{{ tasks.length }} tasks</span></h1>

  <!-- Task Table -->
  <div class="task-table">
    <div class="task-table-header">
      <div class="col-task">TASK</div>
      <div class="col-priority">PRIORITY</div>
      <div class="col-deadline">DEADLINE</div>
      <div class="col-progress">PROGRESS</div>
      <div class="col-status">STATUS</div>
      <div class="col-actions"></div>
    </div>

    <div class="task-row" v-for="task in sortedTasks" :key="task.id" @click="openDetail(task)" :class="{ 'task-done': task.done }">
      <div class="col-task">
        <div class="task-name">
          <i :class="'fas ' + task.icon" :style="{color: task.iconColor}"></i>
          {{ task.title }}
        </div>
        <div class="task-desc">{{ task.description }}</div>
      </div>
      <div class="col-priority">
        <span :class="'tag p' + task.priority">{{ ['🥇','🥈','🥉'][task.priority-1] + ' P' + task.priority }}</span>
      </div>
      <div class="col-deadline">
        <span v-if="task.deadline" :class="'deadline ' + (isUrgent(task.deadline) ? 'warn' : 'ok')">{{ task.deadline }}</span>
        <span v-else class="deadline ok">—</span>
      </div>
      <div class="col-progress">
        <span class="progress-bar"><span class="progress-fill" :style="{width: task.progress + '%'}"></span></span>
        <span class="progress-text">{{ task.progressText }}</span>
      </div>
      <div class="col-status">
        <span :class="'status-badge ' + (task.done ? 'done' : task.status)">
          <i :class="'fas ' + (task.done ? 'fa-check-circle' : task.status === 'in-progress' ? 'fa-circle' : task.status === 'auto' ? 'fa-robot' : 'fa-circle')"></i>
          {{ task.done ? 'Hoàn thành' : statusLabel(task.status) }}
        </span>
      </div>
      <div class="col-actions">
        <div :class="'checkbox ' + (task.done ? 'checked' : '')" @click.stop="toggleTask(task)">
          <i class="fas fa-check" v-if="task.done"></i>
        </div>
      </div>
    </div>
  </div>

  <!-- Detail Modal -->
  <Transition name="fade">
    <div class="modal-overlay" v-if="selectedTask" @click.self="selectedTask=null">
      <div class="modal">
        <button class="modal-close" @click="selectedTask=null">&times;</button>
        
        <h2><i :class="'fas ' + selectedTask.icon" :style="{color: selectedTask.iconColor}"></i> {{ selectedTask.title }}</h2>
        
        <div class="modal-section">
          <div class="modal-meta">
            <div class="modal-meta-item">
              <i class="fas fa-flag"></i> 
              <select class="edit-inline" v-model="editForm.priority" @change="updateTask(selectedTask.id, {priority: editForm.priority})">
                <option :value="1">🥇 P1 - Cao</option>
                <option :value="2">🥈 P2 - Trung</option>
                <option :value="3">🥉 P3 - Thấp</option>
              </select>
            </div>
            <div class="modal-meta-item">
              <i class="fas fa-calendar-alt"></i>
              <input class="edit-inline" v-model="editForm.deadline" placeholder="dd/mm/yyyy" @change="updateTask(selectedTask.id, {deadline: editForm.deadline})">
            </div>
            <div class="modal-meta-item">
              <i class="fas fa-tag"></i> 
              <span v-for="tag in selectedTask.tags" class="tag" style="background:var(--card2);margin:0 2px">{{ tag }}</span>
            </div>
          </div>
        </div>

        <div class="modal-section">
          <h3>📝 Mô tả</h3>
          <textarea class="edit-inline" style="width:100%;min-height:60px;resize:vertical;margin-top:4px" 
            v-model="editForm.description" @change="updateTask(selectedTask.id, {description: editForm.description})"></textarea>
        </div>

        <div class="modal-section">
          <h3>✅ Checklist ({{ doneSubs }}/{{ selectedTask.details.length }}) 
            <span v-if="selectedTask.details && selectedTask.details.length" style="font-weight:400;color:var(--muted);text-transform:none;letter-spacing:0;font-size:12px">
              — {{ selectedTask.progress }}%
            </span>
          </h3>
          <div class="subtask-list">
            <div v-for="(sub, idx) in selectedTask.details" :key="idx" 
                 :class="'subtask-item ' + (sub.done ? 'done' : '')" @click="toggleSubtask(selectedTask.id, idx)">
              <div :class="'checkbox ' + (sub.done ? 'checked' : '')">
                <i class="fas fa-check" v-if="sub.done"></i>
              </div>
              <div class="subtask-label">{{ sub.label }}</div>
              <div class="subtask-value" v-if="sub.value">{{ sub.value }}</div>
            </div>
          </div>
        </div>

        <div class="modal-section" v-if="selectedTask.fileContent">
          <h3>📄 Nội dung file</h3>
          <div class="file-viewer">{{ selectedTask.fileContent }}</div>
        </div>

        <div class="modal-section" v-if="!selectedTask.fileContent && selectedTask.filePath">
          <h3>📄 File</h3>
          <div style="font-size:13px;color:var(--muted)">{{ selectedTask.filePath }}</div>
        </div>
      </div>
    </div>
  </Transition>
</div>

<script>
const { createApp } = Vue;

createApp({
  data() {
    return {
      tasks: [],
      selectedTask: null,
      editForm: { priority: 1, deadline: '', description: '' }
    };
  },
  computed: {
    sortedTasks() {
      return [...this.tasks].sort((a, b) => {
        if (a.done !== b.done) return a.done ? 1 : -1;
        if (a.priority !== b.priority) return a.priority - b.priority;
        return 0;
      });
    },
    doneSubs() {
      if (!this.selectedTask || !this.selectedTask.details) return 0;
      return this.selectedTask.details.filter(s => s.done).length;
    }
  },
  mounted() {
    this.loadTasks();
  },
  methods: {
    async loadTasks() {
      const res = await fetch('/api/tasks');
      this.tasks = await res.json();
    },
    async toggleTask(task) {
      const res = await fetch(`/api/tasks/${task.id}/toggle`, { method: 'POST' });
      const updated = await res.json();
      Object.assign(task, updated);
    },
    async toggleSubtask(taskId, subIdx) {
      const res = await fetch(`/api/tasks/${taskId}/subtask/${subIdx}/toggle`, { method: 'POST' });
      const updated = await res.json();
      // Update the task in our list
      const idx = this.tasks.findIndex(t => t.id === taskId);
      if (idx !== -1) Object.assign(this.tasks[idx], updated);
      if (this.selectedTask && this.selectedTask.id === taskId) {
        Object.assign(this.selectedTask, updated);
      }
    },
    async openDetail(task) {
      const res = await fetch(`/api/tasks/${task.id}`);
      const data = await res.json();
      this.selectedTask = data;
      this.editForm = { 
        priority: data.priority, 
        deadline: data.deadline,
        description: data.description
      };
    },
    async updateTask(taskId, updates) {
      const res = await fetch(`/api/tasks/${taskId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(updates)
      });
      const updated = await res.json();
      const idx = this.tasks.findIndex(t => t.id === taskId);
      if (idx !== -1) Object.assign(this.tasks[idx], updated);
      if (this.selectedTask && this.selectedTask.id === taskId) {
        Object.assign(this.selectedTask, updated);
      }
    },
    statusLabel(s) {
      const map = { 'in-progress': 'Đang làm', 'pending': 'Chờ', 'paused': 'Tạm dừng', 'auto': 'Tự động' };
      return map[s] || s;
    },
    isUrgent(d) {
      if (!d) return false;
      const parts = d.split('/');
      if (parts.length !== 3) return false;
      const deadline = new Date(parts[2], parts[1] - 1, parts[0]);
      const diff = (deadline - new Date()) / (1000 * 60 * 60 * 24);
      return diff <= 3;
    }
  }
}).mount('#app');
</script>
</body>
</html>
